    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "from gtts import gTTS\nimport base64\nimport io\n\n# Lấy nội dung cần đọc từ node trước (biến narration)\ntext_to_read = _input.item.json.narration\n\n# Khởi tạo gTTS với ngôn ngữ tiếng Việt\ntts = gTTS(text=text_to_read, lang='vi')\n\n# Lưu âm thanh vào bộ nhớ đệm (Buffer)\nmp3_fp = io.BytesIO()\ntts.write_to_fp(mp3_fp)\nmp3_fp.seek(0)\n\n# Trả về dữ liệu dưới dạng Binary cho n8n\nreturn {\n    \"json\": _input.item.json,\n    \"binary\": {\n        \"data\": {\n            \"data\": base64.b64encode(mp3_fp.read()).decode('utf-8'),\n            \"fileName\": f\"voice_scene_{_input.item.json.scene}.mp3\",\n            \"fileExtension\": \"mp3\",\n            \"mimeType\": \"audio/mpeg\"\n        }\n    }\n}"
      },
